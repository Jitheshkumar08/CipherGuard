# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
JWT_SECRET=replace-with-a-long-random-secret

# Optional
JWT_EXPIRES_IN=7d
# Comma-separated origins, e.g. https://your-app.vercel.app,https://www.example.com
CORS_ORIGIN=*
# false for API-only deployment (Render + Vercel split)
SERVE_FRONTEND=false
# Mount this to a Render persistent disk path like /var/data/cipherguard/storage
STORAGE_DIR=./storage
